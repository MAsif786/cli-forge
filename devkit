#!/bin/bash
# devkit — Smart CLI Toolbox
# Usage: devkit <tool> [args...]

set -e

DEVKIT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="$DEVKIT_DIR/devkit-lib"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${CYAN}[INFO]${NC} $1"; }
ok()    { echo -e "${GREEN}[OK]${NC}   $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
err()   { echo -e "${RED}[ERR]${NC}  $1"; }

show_usage() {
  echo ""
  echo -e "${BOLD}devkit${NC} — Smart CLI Toolbox"
  echo ""
  echo "Usage: devkit <tool> [args...]"
  echo ""
  echo "Tools:"
  echo "  cleanup   Scan and clean up disk space"
  echo "  curl      Interactive HTTP client (Postman-like)"
  echo "  docker    Interactive Docker manager"
  echo "  totp      TOTP 2FA code manager"
  echo "  vpn       VPN connection manager"
  echo "  help      Show this help"
  echo ""
}

show_tool_help() {
  case "$1" in
    cleanup)
      echo ""
      echo "devkit cleanup — Mac storage cleanup"
      echo ""
      echo "Scans Docker, npm, pip, Homebrew, app caches,"
      echo "Trash, old venvs, Xcode data, and Downloads."
      echo "Then interactively asks what to clean."
      echo ""
      echo "Usage: devkit cleanup"
      echo ""
      ;;
    curl)
      echo ""
      echo "devkit curl — Interactive HTTP client"
      echo ""
      echo "A guided Postman-like HTTP client in your terminal."
      echo "Walks you through method, URL, headers, params, and body."
      echo "Shows the curl command before executing."
      echo ""
      echo "Usage: devkit curl"
      echo ""
      ;;
    docker)
      echo ""
      echo "devkit docker — Interactive Docker manager"
      echo ""
      echo "A guided menu-driven tool for managing Docker."
      echo "List/start/stop/restart/remove containers,"
      echo "view logs, manage images, system prune, disk usage."
      echo ""
      echo "Usage: devkit docker"
      echo ""
      ;;
    totp)
      echo ""
      echo "devkit totp — TOTP 2FA code manager"
      echo ""
      echo "Manage TOTP secrets and generate 2FA codes."
      echo "List all codes with auto-refresh countdown timer."
      echo "Add/remove accounts."
      echo ""
      echo "Requires: oathtool (brew install oath-toolkit)"
      echo "Secrets stored in: ~/.devkit/totp.ini"
      echo ""
      echo "Usage: devkit totp"
      echo ""
      ;;
    vpn)
      echo ""
      echo "devkit vpn — VPN connection manager"
      echo ""
      echo "Connect to OpenVPN configs, manage connections."
      echo "Scans for .ovpn files, connects/disconnects,"
      echo "shows status with public IP check."
      echo ""
      echo "Requires: openvpn (brew install openvpn)"
      echo ""
      echo "Usage: devkit vpn"
      echo ""
      ;;
    *)
      show_usage
      ;;
  esac
}

# ─── Interactive REPL (Node.js / clack) ───────────────

run_interactive() {
  if command -v node &>/dev/null && [ -f "$LIB_DIR/shell/index.js" ]; then
    cd "$LIB_DIR/shell"
    node index.js
    cd "$DEVKIT_DIR"
  elif command -v python3 &>/dev/null && [ -f "$LIB_DIR/shell.py" ]; then
    python3 "$LIB_DIR/shell.py"
  else
    err "Interactive shell requires Node.js or Python 3"
    err "  Install Node: brew install node"
    return 1
  fi
}


# ─── Dispatch helper ──────────────────────────────────

devkit_dispatch() {
  local tool="$1"
  case "$tool" in
    help)
      show_usage
      return 0
      ;;
    cleanup)
      if [ -f "$LIB_DIR/cleanup.sh" ]; then
        source "$LIB_DIR/cleanup.sh"
        run_cleanup
      else
        err "cleanup tool not found at $LIB_DIR/cleanup.sh"
      fi
      ;;
    curl)
      if [ -f "$LIB_DIR/curl.sh" ]; then
        source "$LIB_DIR/curl.sh"
        run_curl
      else
        err "curl tool not found at $LIB_DIR/curl.sh"
      fi
      ;;
    docker)
      if [ -f "$LIB_DIR/docker.sh" ]; then
        source "$LIB_DIR/docker.sh"
        run_docker
      else
        err "docker tool not found at $LIB_DIR/docker.sh"
      fi
      ;;
    totp)
      if [ -f "$LIB_DIR/totp.sh" ]; then
        source "$LIB_DIR/totp.sh"
        run_totp
      else
        err "totp tool not found at $LIB_DIR/totp.sh"
      fi
      ;;
    vpn)
      if [ -f "$LIB_DIR/vpn.sh" ]; then
        source "$LIB_DIR/vpn.sh"
        run_vpn
      else
        err "vpn tool not found at $LIB_DIR/vpn.sh"
      fi
      ;;
    *)
      err "Unknown tool: $tool"
      return 1
      ;;
  esac
}

# No args — interactive REPL
if [ $# -eq 0 ]; then
  run_interactive
  exit 0
fi

TOOL="$1"
shift

case "$TOOL" in
  help)
    if [ $# -ge 1 ]; then
      show_tool_help "$1"
    else
      show_usage
    fi
    ;;
  cleanup|curl|docker|totp|vpn)
    devkit_dispatch "$TOOL"
    ;;
  *)
    err "Unknown tool: $TOOL"
    echo ""
    show_usage
    exit 1
    ;;
esac
