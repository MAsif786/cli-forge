#!/bin/bash
# devkit — Smart CLI Toolbox
# All tools are now JS modules auto-discovered by the Node.js shell.
# Usage: devkit

set -e

DEVKIT_DIR="$(cd "$(dirname "$0")" && pwd)"
SHELL_DIR="$DEVKIT_DIR/devkit-lib/shell"

if [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  echo ""
  echo "devkit — Smart CLI Toolbox"
  echo ""
  echo "Usage: devkit"
  echo ""
  echo "Launches the interactive shell with all available tools."
  echo "Type a tool name to enter its context, / to see commands."
  echo ""
  exit 0
fi

if [ $# -ne 0 ]; then
  echo "devkit: unknown argument '$1' — run without arguments to start the shell"
  exit 1
fi

if ! command -v node &>/dev/null; then
  echo "devkit requires Node.js ≥ 18. Install: brew install node"
  exit 1
fi

cd "$SHELL_DIR"
exec node index.js
